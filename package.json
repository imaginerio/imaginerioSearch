{
  "name": "imaginerio-search",
  "version": "1.0.0",
  "description": "Search API for imagineRio tools",
  "main": "index.js",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npx nodemon index.js",
    "start": "cross-env NODE_ENV=production node index.js",
    "test": "cross-env NODE_ENV=test npx sequelize-cli db:migrate:undo:all && cross-env NODE_ENV=test yarn db:migrate && cross-env NODE_ENV=test yarn jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:job": "yarn db:migrate && node startup",
    "db:migrate:reset": "npx sequelize-cli db:migrate:undo:all && yarn db:migrate && yarn db:seed",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@turf/centroid": "^6.0.2",
    "axios": "^1.7",
    "body-parser": "^1.19.0",
    "colorbrewer": "^1.5.1",
    "cors": "^2.8.5",
    "csv-parse": "^5.0.4",
    "d3-array": "2",
    "d3-scale": "3",
    "dotenv": "^16",
    "express": "^4.21",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "lodash": "^4.17.21",
    "ora": "^5.4.0",
    "pg": "^8.13",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "sequelize": "^6.37",
    "uuid": "^9",
    "wellknown": "^0.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "cross-env": "^7",
    "eslint": "^8",
    "eslint-config-airbnb-base": "^15",
    "eslint-config-prettier": "^9",
    "eslint-plugin-import": "^2.31",
    "eslint-plugin-jest": "^28",
    "eslint-plugin-prettier": "^5",
    "husky": "^9.1.7",
    "jest": "^29",
    "jest-cli": "^29",
    "lint-staged": "^15.2.10",
    "prettier": "^3",
    "prettier-eslint": "^12.0.0",
    "rewire": "^5.0.0",
    "supertest": "^7"
  }
}
