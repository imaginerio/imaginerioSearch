# --- Server ---
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# --- Database ---
# Postgres connection string. Local dev defaults to the value below if unset.
DB_URL=postgresql://postgres:postgres@127.0.0.1/imagineriosearch
DB_NAME=imaginerio

# --- Data ingestion (used by startup + seeders) ---
# Run the migration/seeder pipeline on boot (truthy = on)
STARTUP=
# ArcGIS feature service hosted database name (e.g. imagineRio_GDB)
DATABASE=
# Site mapping key — selects config from config/thematic.js, config/animation.js
MAPPING=rio
# CSV file inside config/ for type names
NAMES_CSV=types.csv
# JSON array of layer names to skip during ingest, e.g. ["CoastLine"]
OMIT=[]
# JSON array of thematic layer names to skip during ingest
THEMATIC=
# Webhook hit after seeding completes
DEPLOY_HOOK=

# --- Auth (for utils/auth.js → ArcGIS OAuth) ---
CLIENT_ID=
USERNAME=
PASSWORD=

# --- Misc ---
# IIIF service base URL (referenced via render.yaml; not read directly by code today)
IIIF=https://iiif.imaginerio.org
# JSON array of collection slugs (referenced via render.yaml)
COLLECTIONS=["maps", "plans", "views", "aerials"]
SMAPSHOT=true
